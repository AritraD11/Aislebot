<?xml version="1.0"?>
<!--
  AisleBot URDF — Asymmetric Mecanum Mobile Robot
  IIT Bombay — Aritra Das (25D0074) — Prof. Ambarish Kunwar

  Geometry:
    Chassis: 1000mm × 500mm × 200mm (L × W × H)
    l1 = 403mm (outer: FR, RL), l2 = 333mm (inner: FL, RR)
    d  = 157.69mm (half-track), wheel_r = 76.2mm
    Total mass ≈ 45.5 kg
-->
<robot name="aislebot" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ==================== MATERIALS ==================== -->
  <material name="dark_gray">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.1 0.3 0.7 1.0"/>
  </material>
  <material name="orange">
    <color rgba="0.9 0.5 0.1 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- ==================== BASE LINK (ground reference) ==================== -->
  <link name="base_link"/>

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 -0.0762" rpy="0 0 0"/>
  </joint>

  <!-- ==================== CHASSIS ==================== -->
  <link name="chassis">
    <visual>
      <geometry>
        <box size="1.0 0.50 0.15"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="1.0 0.50 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="40.0"/>
      <inertia ixx="1.354" ixy="0" ixz="0" iyy="3.688" iyz="0" izz="4.792"/>
    </inertial>
  </link>

  <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
  </joint>

  <!-- ==================== WHEELS ==================== -->
  <!-- Wheel macro: name, parent, xyz offset -->

  <!-- Front-Right (outer: l1 forward, d right) -->
  <link name="wheel_fr">
    <visual>
      <geometry><cylinder radius="0.0762" length="0.06"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0762" length="0.06"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.385"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="wheel_fr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_fr"/>
    <origin xyz="0.403 -0.15769 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Front-Left (inner: l2 forward, d left) -->
  <link name="wheel_fl">
    <visual>
      <geometry><cylinder radius="0.0762" length="0.06"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0762" length="0.06"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.385"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="wheel_fl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_fl"/>
    <origin xyz="0.333 0.15769 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rear-Right (inner: l2 backward, d right) -->
  <link name="wheel_rr">
    <visual>
      <geometry><cylinder radius="0.0762" length="0.06"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0762" length="0.06"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.385"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="wheel_rr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rr"/>
    <origin xyz="-0.333 -0.15769 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rear-Left (outer: l1 backward, d left) -->
  <link name="wheel_rl">
    <visual>
      <geometry><cylinder radius="0.0762" length="0.06"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0762" length="0.06"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.385"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="wheel_rl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rl"/>
    <origin xyz="-0.403 0.15769 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ==================== SENSOR FRAMES ==================== -->

  <!-- LiDAR mount (front-center, 20cm above base) -->
  <link name="laser_frame">
    <visual>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0.35 0 0.20" rpy="0 0 0"/>
  </joint>

  <!-- IMU (center of chassis) -->
  <link name="imu_link">
    <visual>
      <geometry><box size="0.02 0.02 0.005"/></geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ==================== GAZEBO PLUGIN ==================== -->
  <gazebo>
    <plugin name="object_controller" filename="libgazebo_ros_planar_move.so">
      <ros>
        <namespace>/</namespace>
        <argument>cmd_vel:=cmd_vel</argument>
        <argument>odom:=sim_odom</argument>
      </ros>
      <update_rate>100</update_rate>
      <publish_rate>50</publish_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>false</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- Gazebo colors -->
  <gazebo reference="chassis">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="wheel_fr"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="wheel_fl"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="wheel_rr"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="wheel_rl"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="laser_frame"><material>Gazebo/Blue</material></gazebo>

  <!-- Simulated LiDAR sensor -->
  <gazebo reference="laser_frame">
    <sensor type="ray" name="rplidar">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Simulated IMU -->
  <gazebo reference="imu_link">
    <sensor type="imu" name="imu_sensor">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
        <frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
